# .env.example
# Template for auth-service's local environment variables.
# Copy this to .env (gitignored) and fill in real values - .env is what, if exported
# into your shell, the Spring Boot app itself will actually read.

# --- Postgres (a dedicated role/database on your local Postgres 18 instance) ---
DB_NAME=auth_service_db
DB_USERNAME=auth_service
DB_PASSWORD=change-me

# --- JWT (consumed by application.properties) ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=3600000
