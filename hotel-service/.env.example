# .env.example
# Template for hotel-service's local environment variables.
# Copy this to .env (gitignored) and fill in real values.

# --- Postgres (a dedicated role/database on the same Postgres instance
#     auth-service/user-service use) ---
# DB_HOST/DB_PORT are optional - default to 127.0.0.1:5432 (native local Postgres).
# docker-compose overrides DB_HOST to the Postgres service's container name instead.
DB_NAME=hotel_service_db
DB_USERNAME=hotel_service
DB_PASSWORD=change-me

# --- JWT (consumed by application.properties) ---
# MUST be the exact same value as auth-service's JWT_SECRET - this service
# only validates tokens auth-service issues, it never signs its own.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
