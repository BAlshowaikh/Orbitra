# .env.example (repo root)
# Template for docker-compose's own variable substitution - Docker Compose
# automatically reads a .env file in the same directory as docker-compose.yml
# to resolve ${VAR} references written inside it. Copy this to .env (gitignored)
# and fill in real values.

# --- Postgres bootstrap superuser (init-only, no app connects with this) ---
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# --- auth-service's dedicated database + user (created by init.sh) ---
AUTH_DB_NAME=auth_service_db
AUTH_DB_USER=auth_service
AUTH_DB_PASSWORD=change-me

# --- user-service's dedicated database + user (created by init.sh) ---
USER_DB_NAME=user_service_db
USER_DB_USER=user_service
USER_DB_PASSWORD=change-me

# --- Shared JWT secret - auth-service issues tokens, user-service only
#     validates them, so both services must use this exact same value ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=3600000
